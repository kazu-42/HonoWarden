{
  "name": "token-password-grant-success",
  "endpoint": {
    "method": "POST",
    "path": "/identity/connect/token"
  },
  "request": {
    "headers": {
      "content-type": "application/x-www-form-urlencoded",
      "device-identifier": "fixture-device",
      "device-name": "Fixture Device",
      "device-type": "9"
    },
    "form": {
      "grant_type": "password",
      "username": "person@example.test",
      "password": "synthetic-master-password-hash",
      "scope": "api offline_access"
    }
  },
  "response": {
    "status": 200,
    "body": {
      "access_token": "synthetic-access-token",
      "refresh_token": "synthetic-refresh-token",
      "token_type": "Bearer",
      "expires_in": 3600,
      "Key": "2.c3ludGhldGljLXVzZXIta2V5",
      "PrivateKey": null,
      "Kdf": 0,
      "KdfIterations": 600000,
      "KdfMemory": null,
      "KdfParallelism": null,
      "AccountKeys": null,
      "ForcePasswordReset": false,
      "TwoFactorToken": null,
      "MasterPasswordPolicy": null,
      "UserDecryptionOptions": null,
      "KeyConnectorUrl": null
    }
  },
  "assertions": [
    {
      "path": "$.access_token",
      "type": "string"
    },
    {
      "path": "$.refresh_token",
      "type": "string"
    },
    {
      "path": "$.token_type",
      "type": "string",
      "value": "Bearer"
    },
    {
      "path": "$.expires_in",
      "type": "number"
    },
    {
      "path": "$.Key",
      "type": "string"
    },
    {
      "path": "$.Kdf",
      "type": "number",
      "value": 0
    },
    {
      "path": "$.KdfIterations",
      "type": "number",
      "value": 600000
    },
    {
      "path": "$.ForcePasswordReset",
      "type": "boolean",
      "value": false
    }
  ]
}
