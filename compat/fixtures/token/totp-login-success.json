{
  "name": "token-totp-login-success",
  "endpoint": {
    "method": "POST",
    "path": "/identity/connect/token"
  },
  "request": {
    "headers": {
      "content-type": "application/x-www-form-urlencoded",
      "device-identifier": "fixture-device"
    },
    "form": {
      "grant_type": "password",
      "username": "person@example.test",
      "password": "synthetic-master-password-hash",
      "twoFactorToken": "synthetic-two-factor-token",
      "twoFactorProvider": "totp",
      "twoFactorCode": "123456"
    }
  },
  "response": {
    "status": 200,
    "body": {
      "access_token": "synthetic-access-token",
      "refresh_token": "synthetic-refresh-token",
      "token_type": "Bearer",
      "expires_in": 3600,
      "Key": "2.c3ludGhldGljLXVzZXIta2V5",
      "PrivateKey": "2.synthetic-private-key",
      "Kdf": 0,
      "KdfIterations": 600000,
      "KdfMemory": null,
      "KdfParallelism": null,
      "AccountKeys": {
        "publicKeyEncryptionKeyPair": {
          "publicKey": "synthetic-public-key",
          "wrappedPrivateKey": "2.synthetic-private-key"
        }
      },
      "ForcePasswordReset": false,
      "TwoFactorToken": null,
      "MasterPasswordPolicy": null,
      "UserDecryptionOptions": {
        "HasMasterPassword": true,
        "MasterPasswordUnlock": {
          "Salt": "person@example.test",
          "Kdf": {
            "KdfType": 0,
            "Iterations": 600000
          },
          "MasterKeyEncryptedUserKey": "2.c3ludGhldGljLXVzZXIta2V5"
        }
      },
      "KeyConnectorUrl": null
    }
  },
  "assertions": [
    {
      "path": "$.access_token",
      "type": "string"
    },
    {
      "path": "$.refresh_token",
      "type": "string"
    },
    {
      "path": "$.token_type",
      "type": "string",
      "value": "Bearer"
    },
    {
      "path": "$.TwoFactorToken",
      "type": "null"
    },
    {
      "path": "$.AccountKeys.publicKeyEncryptionKeyPair.wrappedPrivateKey",
      "type": "string"
    },
    {
      "path": "$.UserDecryptionOptions.HasMasterPassword",
      "type": "boolean",
      "value": true
    },
    {
      "path": "$.KdfIterations",
      "type": "number",
      "value": 600000
    }
  ]
}
