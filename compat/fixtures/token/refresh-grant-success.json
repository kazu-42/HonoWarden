{
  "name": "token-refresh-grant-success",
  "endpoint": {
    "method": "POST",
    "path": "/identity/connect/token"
  },
  "request": {
    "headers": {
      "content-type": "application/x-www-form-urlencoded"
    },
    "form": {
      "grant_type": "refresh_token",
      "refresh_token": "synthetic-refresh-token"
    }
  },
  "response": {
    "status": 200,
    "body": {
      "access_token": "synthetic-access-token",
      "refresh_token": "synthetic-next-refresh-token",
      "token_type": "Bearer",
      "expires_in": 3600,
      "Key": "2.c3ludGhldGljLXVzZXIta2V5",
      "PrivateKey": "2.synthetic-private-key",
      "Kdf": 0,
      "KdfIterations": 600000,
      "KdfMemory": null,
      "KdfParallelism": null,
      "AccountKeys": {
        "publicKeyEncryptionKeyPair": {
          "publicKey": "synthetic-public-key",
          "wrappedPrivateKey": "2.synthetic-private-key"
        }
      },
      "ForcePasswordReset": false,
      "TwoFactorToken": null,
      "MasterPasswordPolicy": null,
      "UserDecryptionOptions": {
        "HasMasterPassword": true,
        "MasterPasswordUnlock": {
          "Salt": "person@example.test",
          "Kdf": {
            "KdfType": 0,
            "Iterations": 600000
          },
          "MasterKeyEncryptedUserKey": "2.c3ludGhldGljLXVzZXIta2V5"
        }
      },
      "KeyConnectorUrl": null
    }
  },
  "assertions": [
    {
      "path": "$.access_token",
      "type": "string"
    },
    {
      "path": "$.refresh_token",
      "type": "string",
      "notValue": "synthetic-refresh-token"
    },
    {
      "path": "$.token_type",
      "type": "string",
      "value": "Bearer"
    },
    {
      "path": "$.expires_in",
      "type": "number"
    },
    {
      "path": "$.AccountKeys.publicKeyEncryptionKeyPair.publicKey",
      "type": "string"
    },
    {
      "path": "$.UserDecryptionOptions.MasterPasswordUnlock.Kdf.Iterations",
      "type": "number",
      "value": 600000
    },
    {
      "path": "$.Kdf",
      "type": "number",
      "value": 0
    },
    {
      "path": "$.KdfIterations",
      "type": "number",
      "value": 600000
    }
  ]
}
