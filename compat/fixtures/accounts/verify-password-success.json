{
  "name": "account-verify-password-success",
  "endpoint": {
    "method": "POST",
    "path": "/api/accounts/verify-password"
  },
  "request": {
    "headers": {
      "authorization": "Bearer synthetic-access-token"
    },
    "body": {
      "masterPasswordHash": "synthetic-master-password-hash"
    }
  },
  "response": {
    "status": 200,
    "body": {
      "object": "masterPasswordPolicy",
      "minComplexity": null,
      "minLength": null,
      "requireLower": null,
      "requireUpper": null,
      "requireNumbers": null,
      "requireSpecial": null,
      "enforceOnLogin": null
    }
  },
  "assertions": [
    {
      "path": "$.object",
      "type": "string",
      "value": "masterPasswordPolicy"
    },
    {
      "path": "$.minLength",
      "type": "null",
      "value": null
    },
    {
      "path": "$.enforceOnLogin",
      "type": "null",
      "value": null
    }
  ]
}
