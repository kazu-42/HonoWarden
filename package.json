{
  "name": "honowarden",
  "version": "0.0.0",
  "description": "A minimal, API-only Bitwarden-compatible server for Cloudflare Workers, built with Hono, D1, and R2.",
  "type": "module",
  "license": "AGPL-3.0-or-later",
  "private": false,
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=11.0.0"
  },
  "keywords": [
    "bitwarden",
    "cloudflare-workers",
    "d1",
    "hono",
    "password-manager",
    "r2",
    "vault"
  ],
  "scripts": {
    "check": "tsc --noEmit",
    "cf:typegen": "wrangler types",
    "deploy": "wrangler deploy",
    "dev": "wrangler dev",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "hono": "^4.12.27"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.6.0",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.10",
    "wrangler": "^4.107.0"
  }
}
