{
  "name": "honowarden",
  "version": "0.1.0-alpha",
  "description": "A minimal, API-only encrypted vault sync server for Cloudflare Workers, built with Hono, D1, and R2.",
  "type": "module",
  "license": "AGPL-3.0-or-later",
  "private": false,
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=22.13.0",
    "pnpm": ">=11.0.0"
  },
  "keywords": [
    "cloudflare-workers",
    "d1",
    "hono",
    "password-manager",
    "r2",
    "vault"
  ],
  "scripts": {
    "check": "tsc --noEmit",
    "account:lifecycle": "node scripts/honowarden-account-lifecycle.mjs",
    "account:kdf-change:lifecycle": "node scripts/honowarden-kdf-change-lifecycle.mjs",
    "account:credential-lifecycle": "node scripts/honowarden-credential-lifecycle.mjs",
    "account:credential-forward-recovery": "node scripts/honowarden-credential-forward-recovery.mjs",
    "account:credential-restore:lifecycle": "node scripts/honowarden-credential-restore-lifecycle.mjs",
    "account:key-rotation:lifecycle": "node scripts/honowarden-user-key-rotation-lifecycle.mjs",
    "account:keys:lifecycle": "node scripts/honowarden-account-key-lifecycle.mjs",
    "account:password-change:lifecycle": "node scripts/honowarden-password-change-lifecycle.mjs",
    "abuse:report": "node scripts/honowarden-abuse-report.mjs",
    "backup:export": "node scripts/honowarden-backup.mjs export",
    "backup:evidence": "node scripts/honowarden-backup.mjs evidence",
    "backup:restore": "node scripts/honowarden-backup.mjs restore",
    "backup:schedule:packet": "node scripts/honowarden-scheduled-backup-packet.mjs plan",
    "cf:typegen": "wrangler types",
    "compat:test": "vitest run test/compat",
    "brand:scan": "node scripts/honowarden-brand-scan.mjs",
    "cloudflare:tokens": "node scripts/honowarden-cloudflare-token-remediation.mjs",
    "client:auth-fixture": "node scripts/honowarden-client-auth-fixture.mjs",
    "client:browser-profile": "node scripts/honowarden-browser-profile.mjs",
    "client:official-harness": "node scripts/honowarden-official-client-harness.mjs",
    "credential:evidence:verify": "node scripts/honowarden-credential-evidence.mjs",
    "db:migrate:local": "wrangler d1 migrations apply honowarden --local",
    "deploy": "wrangler deploy",
    "dev": "wrangler dev",
    "dogfood:evidence:packet": "node scripts/honowarden-dogfood-evidence-packet.mjs",
    "email:preflight": "node scripts/honowarden-email-preflight.mjs",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "linear:apply-plan": "node scripts/honowarden-linear-apply-plan.mjs",
    "linear:mutation-packet": "node scripts/honowarden-linear-mutation-packet.mjs",
    "linear:preflight": "node scripts/honowarden-linear-preflight.mjs",
    "linear:request-plan": "node scripts/honowarden-linear-request-plan.mjs",
    "linear:resolution-plan": "node scripts/honowarden-linear-resolution-plan.mjs",
    "linear:seed": "node scripts/honowarden-linear-seed.mjs",
    "live:regression:packet": "node scripts/honowarden-live-regression-packet.mjs",
    "usable:acceptance:verify": "node scripts/honowarden-usable-state-acceptance.mjs",
    "lint": "eslint .",
    "ops:readiness:packet": "node scripts/honowarden-ops-readiness-packet.mjs",
    "release:approval:packet": "node scripts/honowarden-release-approval-packet.mjs",
    "release:completion:audit": "node scripts/honowarden-alpha-completion-audit.mjs",
    "release:evidence:bundle": "node scripts/honowarden-release-evidence-bundle.mjs",
    "release:gate": "node scripts/honowarden-release-gate.mjs",
    "release:github:plan": "node scripts/honowarden-github-release-plan.mjs",
    "release:post-tag:packet": "node scripts/honowarden-post-tag-release-packet.mjs",
    "release:published:packet": "node scripts/honowarden-release-published-packet.mjs",
    "release:publish:packet": "node scripts/honowarden-release-publish-packet.mjs",
    "release:status:packet": "node scripts/honowarden-release-status-packet.mjs",
    "release:tag:recovery": "node scripts/honowarden-release-tag-recovery-packet.mjs",
    "release:tag:preflight": "node scripts/honowarden-alpha-tag-preflight.mjs",
    "secret:rotation:drill": "node scripts/honowarden-secret-rotation-drill.mjs",
    "staging:dry-run": "node scripts/honowarden-staging-dry-run.mjs",
    "totp:rotate-secret": "node scripts/honowarden-totp-secret-rotation.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@microsoft/signalr": "^10.0.0",
    "@microsoft/signalr-protocol-msgpack": "^10.0.0",
    "hono": "^4.12.30"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "eslint": "^10.7.0",
    "jsonc-parser": "^3.3.1",
    "miniflare": "4.20260714.0",
    "prettier": "^3.9.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10",
    "wrangler": "^4.112.0"
  }
}
