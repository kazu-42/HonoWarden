{
  "name": "honowarden",
  "version": "0.1.0-alpha",
  "description": "A minimal, API-only encrypted vault sync server for Cloudflare Workers, built with Hono, D1, and R2.",
  "type": "module",
  "license": "AGPL-3.0-or-later",
  "private": false,
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=11.0.0"
  },
  "keywords": [
    "cloudflare-workers",
    "d1",
    "hono",
    "password-manager",
    "r2",
    "vault"
  ],
  "scripts": {
    "check": "tsc --noEmit",
    "backup:export": "node scripts/honowarden-backup.mjs export",
    "backup:restore": "node scripts/honowarden-backup.mjs restore",
    "cf:typegen": "wrangler types",
    "compat:test": "vitest run test/compat",
    "db:migrate:local": "wrangler d1 migrations apply honowarden --local",
    "deploy": "wrangler deploy",
    "dev": "wrangler dev",
    "email:preflight": "node scripts/honowarden-email-preflight.mjs",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "linear:seed": "node scripts/honowarden-linear-seed.mjs",
    "lint": "eslint .",
    "release:approval:packet": "node scripts/honowarden-release-approval-packet.mjs",
    "release:evidence:bundle": "node scripts/honowarden-release-evidence-bundle.mjs",
    "release:gate": "node scripts/honowarden-release-gate.mjs",
    "release:github:plan": "node scripts/honowarden-github-release-plan.mjs",
    "release:post-tag:packet": "node scripts/honowarden-post-tag-release-packet.mjs",
    "release:tag:preflight": "node scripts/honowarden-alpha-tag-preflight.mjs",
    "staging:dry-run": "node scripts/honowarden-staging-dry-run.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "hono": "^4.12.27"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.0",
    "eslint": "^10.6.0",
    "jsonc-parser": "^3.3.1",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.10",
    "wrangler": "^4.107.0"
  }
}
