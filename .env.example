# Copy this file to .env.local. Do not put real secrets in tracked files.

# Linear
LINEAR_API_KEY=

# GitHub automation, only needed when creating or updating the website repo
GITHUB_TOKEN=

# Cloudflare account and honowarden.com zone
# Bind this generic variable command-locally to the workflow-specific scoped
# token below. Routine Cloudflare automation must not use a broad credential.
CLOUDFLARE_API_TOKEN=
# Break-glass only: these values are accepted by scoped-token remediation and
# the rotation drill, never as fallback for routine workflows.
CLOUDFLARE_API_KEY=
CLOUDFLARE_GLOBAL_API_KEY=
CLOUDFLARE_EMAIL=
CLOUDFLARE_API_EMAIL=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID_HONOWARDEN_COM=
CLOUDFLARE_HONOWARDEN_DEPLOY_TOKEN=
CLOUDFLARE_HONOWARDEN_DNS_ROUTES_TOKEN=
CLOUDFLARE_HONOWARDEN_EMAIL_ROUTING_TOKEN=
CLOUDFLARE_HONOWARDEN_D1_R2_TOKEN=
CLOUDFLARE_HONOWARDEN_READONLY_TOKEN=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
HONOWARDEN_BACKUP_ARCHIVE_PASSPHRASE=

# Destination inboxes must be verified in Cloudflare Email Routing before use.
HONOWARDEN_SECURITY_FORWARD_TO=
HONOWARDEN_SUPPORT_FORWARD_TO=
HONOWARDEN_GENERAL_FORWARD_TO=
HONOWARDEN_ADMIN_FORWARD_TO=
HONOWARDEN_POSTMASTER_FORWARD_TO=
HONOWARDEN_ABUSE_FORWARD_TO=

# Inquiry inbox Email Worker local smoke. HONOWARDEN_INQUIRY_FORWARD_TO must be
# a verified Cloudflare Email Routing destination before live use.
HONOWARDEN_INQUIRY_DOMAINS=honowarden.com
HONOWARDEN_INQUIRY_MAILBOXES=security,support,hello,admin,postmaster,abuse
HONOWARDEN_INQUIRY_MAX_RAW_BYTES=1000000
HONOWARDEN_INQUIRY_FORWARD_TO=

# Worker runtime secrets are set through Wrangler, not loaded into production
# from direnv. Keep these local-only unless intentionally running local smoke.
HONOWARDEN_BOOTSTRAP_TOKEN=
HONOWARDEN_ACCESS_TOKEN_ACTIVE_KID=
HONOWARDEN_ACCESS_TOKEN_ACTIVE_SECRET=
HONOWARDEN_ACCESS_TOKEN_PREVIOUS_KEYS=
HONOWARDEN_ACCOUNT_KEYS_ENABLED=false
HONOWARDEN_AUTH_REQUESTS_ENABLED=false
HONOWARDEN_AUTH_REQUEST_SECRET=
HONOWARDEN_GLOBAL_REQUEST_QUOTA=false
HONOWARDEN_KDF_MUTATION_ENABLED=false
HONOWARDEN_PREMIUM_FEATURES_ENABLED=false
HONOWARDEN_REFRESH_TOKEN_RETENTION_ENABLED=false
HONOWARDEN_TOKEN_SECRET=
HONOWARDEN_TOTP_OLD_SECRET=
HONOWARDEN_TOTP_NEW_SECRET=
HONOWARDEN_TOTP_SECRET=

# WebAuthn policy inputs are non-secret but environment-specific. HON-208 adds
# only fail-closed parsing; it does not add routes or enable runtime support.
HONOWARDEN_WEBAUTHN_ENABLED=false
HONOWARDEN_WEBAUTHN_RP_ID=
HONOWARDEN_WEBAUTHN_ORIGINS=
HONOWARDEN_WEBAUTHN_ALLOW_INSECURE_LOCALHOST=false
