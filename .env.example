# Copy this file to .env.local. Do not put real secrets in tracked files.

# Linear
LINEAR_API_KEY=

# GitHub automation, only needed when creating or updating the website repo
GITHUB_TOKEN=

# Cloudflare account and honowarden.com zone
CLOUDFLARE_API_TOKEN=
# Fallback for local-only Cloudflare automation when a scoped token is not
# available. Prefer CLOUDFLARE_API_TOKEN for normal operation.
CLOUDFLARE_API_KEY=
CLOUDFLARE_GLOBAL_API_KEY=
CLOUDFLARE_EMAIL=
CLOUDFLARE_API_EMAIL=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID_HONOWARDEN_COM=
CLOUDFLARE_HONOWARDEN_DEPLOY_TOKEN=
CLOUDFLARE_HONOWARDEN_DNS_ROUTES_TOKEN=
CLOUDFLARE_HONOWARDEN_EMAIL_ROUTING_TOKEN=
CLOUDFLARE_HONOWARDEN_D1_R2_TOKEN=
CLOUDFLARE_HONOWARDEN_READONLY_TOKEN=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
HONOWARDEN_BACKUP_ARCHIVE_PASSPHRASE=

# Destination inboxes must be verified in Cloudflare Email Routing before use.
HONOWARDEN_SECURITY_FORWARD_TO=
HONOWARDEN_SUPPORT_FORWARD_TO=
HONOWARDEN_GENERAL_FORWARD_TO=
HONOWARDEN_ADMIN_FORWARD_TO=
HONOWARDEN_POSTMASTER_FORWARD_TO=
HONOWARDEN_ABUSE_FORWARD_TO=

# Worker runtime secrets are set through Wrangler, not loaded into production
# from direnv. Keep these local-only unless intentionally running local smoke.
HONOWARDEN_BOOTSTRAP_TOKEN=
HONOWARDEN_ACCESS_TOKEN_ACTIVE_KID=
HONOWARDEN_ACCESS_TOKEN_ACTIVE_SECRET=
HONOWARDEN_ACCESS_TOKEN_PREVIOUS_KEYS=
HONOWARDEN_GLOBAL_REQUEST_QUOTA=false
HONOWARDEN_INQUIRY_DOMAIN=honowarden.com
HONOWARDEN_INQUIRY_MAILBOXES=security,support,hello,admin,postmaster,abuse,inquiry-smoke
HONOWARDEN_TOKEN_SECRET=
HONOWARDEN_TOTP_OLD_SECRET=
HONOWARDEN_TOTP_NEW_SECRET=
HONOWARDEN_TOTP_SECRET=
