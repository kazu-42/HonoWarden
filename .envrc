# Project-local, non-secret defaults for direnv.
# Secrets live in .env.local or .envrc.local, both ignored by git.

export HONOWARDEN_DOMAIN=honowarden.com
export HONOWARDEN_REPOSITORY_URL=https://github.com/kazu-42/HonoWarden
export HONOWARDEN_WEBSITE_REPOSITORY_NAME=HonoWarden-website
export HONOWARDEN_WEBSITE_REPOSITORY_URL=https://github.com/kazu-42/HonoWarden-website
export HONOWARDEN_LINEAR_URL=https://linear.app/honowarden/
export HONOWARDEN_LINEAR_WORKSPACE_SLUG=honowarden
export HONOWARDEN_CLOUDFLARE_ZONE_NAME=honowarden.com

watch_file .env.local
watch_file .envrc.local
source_env_if_exists .env.local
source_env_if_exists .envrc.local
